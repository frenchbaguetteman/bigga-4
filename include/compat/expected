// Minimal std::expected shim for GCC 10.x which lacks C++23 <expected>.
// Only enough to satisfy PROS kernel 4.2.2 header parsing.
#pragma once

#include <utility>
#include <type_traits>

#if __cplusplus >= 202302L && __has_include_next(<expected>)
#  include_next <expected>          // use the real header when available
#else

namespace std {

template <class E>
class unexpected {
    E m_err;
public:
    constexpr explicit unexpected(const E& e) : m_err(e) {}
    constexpr explicit unexpected(E&& e) : m_err(std::move(e)) {}
    constexpr const E& error() const& noexcept { return m_err; }
    constexpr E& error() & noexcept { return m_err; }
    constexpr E&& error() && noexcept { return std::move(m_err); }
};

template <class E>
unexpected(E) -> unexpected<E>;

template <class T, class E>
class expected {
    union {
        T m_val;
        E m_err;
    };
    bool m_has;

public:
    using value_type = T;
    using error_type = E;
    using unexpected_type = unexpected<E>;

    // ── constructors ──
    constexpr expected() : m_val{}, m_has(true) {}
    constexpr expected(const T& v) : m_val(v), m_has(true) {}
    constexpr expected(T&& v) : m_val(std::move(v)), m_has(true) {}
    constexpr expected(const unexpected<E>& u) : m_err(u.error()), m_has(false) {}
    constexpr expected(unexpected<E>&& u) : m_err(std::move(u).error()), m_has(false) {}

    constexpr expected(const expected& o) : m_has(o.m_has) {
        if (m_has) new (&m_val) T(o.m_val);
        else       new (&m_err) E(o.m_err);
    }
    constexpr expected(expected&& o) noexcept : m_has(o.m_has) {
        if (m_has) new (&m_val) T(std::move(o.m_val));
        else       new (&m_err) E(std::move(o.m_err));
    }

    ~expected() {
        if (m_has) m_val.~T();
        else       m_err.~E();
    }

    expected& operator=(const expected& o) {
        if (this != &o) { this->~expected(); new (this) expected(o); }
        return *this;
    }
    expected& operator=(expected&& o) noexcept {
        if (this != &o) { this->~expected(); new (this) expected(std::move(o)); }
        return *this;
    }

    // ── observers ──
    constexpr bool has_value() const noexcept { return m_has; }
    constexpr explicit operator bool() const noexcept { return m_has; }

    constexpr T& value() & { return m_val; }
    constexpr const T& value() const& { return m_val; }
    constexpr T&& value() && { return std::move(m_val); }

    constexpr T& operator*() & { return m_val; }
    constexpr const T& operator*() const& { return m_val; }
    constexpr T* operator->() { return &m_val; }
    constexpr const T* operator->() const { return &m_val; }

    constexpr E& error() & { return m_err; }
    constexpr const E& error() const& { return m_err; }
    constexpr E&& error() && { return std::move(m_err); }

    template <class U>
    constexpr T value_or(U&& v) const& {
        return m_has ? m_val : static_cast<T>(std::forward<U>(v));
    }
};

// Void specialisation (used in some PROS APIs)
template <class E>
class expected<void, E> {
    union { E m_err; };
    bool m_has;
public:
    using value_type = void;
    using error_type = E;
    using unexpected_type = unexpected<E>;

    constexpr expected() noexcept : m_has(true) {}
    constexpr expected(const unexpected<E>& u) : m_err(u.error()), m_has(false) {}
    constexpr expected(unexpected<E>&& u) : m_err(std::move(u).error()), m_has(false) {}

    constexpr expected(const expected& o) : m_has(o.m_has) {
        if (!m_has) new (&m_err) E(o.m_err);
    }
    ~expected() { if (!m_has) m_err.~E(); }

    expected& operator=(const expected& o) {
        if (this != &o) { this->~expected(); new (this) expected(o); }
        return *this;
    }

    constexpr bool has_value() const noexcept { return m_has; }
    constexpr explicit operator bool() const noexcept { return m_has; }
    constexpr E& error() & { return m_err; }
    constexpr const E& error() const& { return m_err; }
};

} // namespace std
#endif
